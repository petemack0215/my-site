<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mac Peters</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #f5f0e8;
      --dark: #1a1814;
      --mid: #6b6560;
      --accent: #c4a882;
      --white: #fdfcf9;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--dark);
      font-weight: 300;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem 3rem;
      background: rgba(245, 240, 232, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(196, 168, 130, 0.2);
    }

    .nav-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      letter-spacing: 0.02em;
      text-decoration: none;
      color: var(--dark);
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--mid);
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--dark); }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 8rem 3rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -10%;
      right: -5%;
      width: 55%;
      height: 110%;
      background: linear-gradient(135deg, var(--accent) 0%, #a08060 100%);
      opacity: 0.12;
      border-radius: 2px;
      transform: skewX(-3deg);
    }

    .hero-content {
      max-width: 680px;
      animation: fadeUp 0.9s ease both;
    }

    .hero-eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 1.1;
      margin-bottom: 1.5rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--mid);
    }

    .hero p {
      font-size: 1.1rem;
      line-height: 1.7;
      color: var(--mid);
      max-width: 480px;
      margin-bottom: 2.5rem;
    }

    .hero-btns {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 0.8rem 2rem;
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: all 0.2s;
      border: 1px solid var(--dark);
      color: var(--dark);
      background: transparent;
    }

    .btn:hover {
      background: var(--dark);
      color: var(--cream);
    }

    .btn-filled {
      background: var(--dark);
      color: var(--cream);
    }

    .btn-filled:hover {
      background: transparent;
      color: var(--dark);
    }

    /* SECTION SHARED */
    section {
      padding: 6rem 3rem;
    }

    .section-label {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      margin-bottom: 1.5rem;
      line-height: 1.2;
    }

    /* ABOUT */
    .about {
      background: var(--white);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .about-text p {
      color: var(--mid);
      line-height: 1.8;
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .stat-item {
      border-top: 1px solid var(--accent);
      padding-top: 1.5rem;
    }

    .stat-number {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      line-height: 1;
      margin-bottom: 0.4rem;
    }

    .stat-label {
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--mid);
    }

    /* SERVICES */
    .services { background: var(--cream); }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-top: 3rem;
    }

    .service-card {
      background: var(--white);
      padding: 2.5rem;
      transition: background 0.25s;
    }

    .service-card:hover { background: var(--dark); color: var(--cream); }
    .service-card:hover .service-desc { color: rgba(245,240,232,0.6); }
    .service-card:hover .service-num { color: var(--accent); }

    .service-num {
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }

    .service-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }

    .service-desc {
      font-size: 0.9rem;
      line-height: 1.7;
      color: var(--mid);
    }

    /* CONTACT */
    .contact {
      background: var(--dark);
      color: var(--cream);
      text-align: center;
    }

    .contact .section-title { color: var(--cream); }

    .contact p {
      color: rgba(245,240,232,0.6);
      max-width: 500px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .contact .btn {
      border-color: var(--accent);
      color: var(--accent);
    }

    .contact .btn:hover {
      background: var(--accent);
      color: var(--dark);
    }

    .contact-email {
      display: block;
      margin-top: 2rem;
      font-size: 0.85rem;
      color: rgba(245,240,232,0.4);
      letter-spacing: 0.05em;
    }

    /* FOOTER */
    footer {
      background: var(--dark);
      border-top: 1px solid rgba(245,240,232,0.1);
      padding: 2rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer span {
      font-size: 0.8rem;
      color: rgba(245,240,232,0.3);
      letter-spacing: 0.05em;
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      nav { padding: 1.2rem 1.5rem; }
      .nav-links { gap: 1.5rem; }
      .hero { padding: 7rem 1.5rem 3rem; }
      section { padding: 4rem 1.5rem; }
      .about { grid-template-columns: 1fr; gap: 3rem; }
      .services-grid { grid-template-columns: 1fr; }
      footer { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
  </style>
</head>
<body>

  <nav>
    <a class="nav-name" href="#">Mac Peters</a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#work">Work</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow">Photographer &amp; Creative</p>
      <h1>Capturing <em>stories</em><br>worth telling</h1>
      <p>I use visual storytelling to capture the moments, places, and people that matter most. Based in the mountains — available everywhere.</p>
      <div class="hero-btns">
        <a href="#work" class="btn btn-filled">View My Work</a>
        <a href="#contact" class="btn">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="about-text">
      <p class="section-label">About</p>
      <h2 class="section-title">Hey, I'm Mac.</h2>
      <p>I'm a photographer and visual storyteller with a passion for adventure, the outdoors, and the moments in between. Whether it's a wedding in the mountains or a brand campaign in the backcountry, I bring the same intention to every frame.</p>
      <p>I believe great photography isn't about gear — it's about trust, timing, and seeing what others walk past.</p>
    </div>
    <div class="about-stats">
      <div class="stat-item">
        <div class="stat-number">8+</div>
        <div class="stat-label">Years shooting</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">200+</div>
        <div class="stat-label">Projects completed</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">12</div>
        <div class="stat-label">States covered</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">∞</div>
        <div class="stat-label">Stories left to tell</div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="work">
    <p class="section-label">What I Do</p>
    <h2 class="section-title">Work</h2>
    <div class="services-grid">
      <div class="service-card">
        <p class="service-num">01</p>
        <h3 class="service-name">Photography</h3>
        <p class="service-desc">From adventure sports to portraits and landscapes — every shoot is approached with intention and care for the story being told.</p>
      </div>
      <div class="service-card">
        <p class="service-num">02</p>
        <h3 class="service-name">Weddings</h3>
        <p class="service-desc">Documentary-style wedding photography that captures the real emotion of your day — candid, honest, and beautiful.</p>
      </div>
      <div class="service-card">
        <p class="service-num">03</p>
        <h3 class="service-name">Brand & Design</h3>
        <p class="service-desc">Visual identity, social content, and creative direction for brands that want to stand out and say something real.</p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <p class="section-label" style="color: var(--accent);">Let's Connect</p>
    <h2 class="section-title">Got a project in mind?</h2>
    <p>Whether you have a clear vision or just a vague idea, I'd love to hear about it. Drop me a line and let's see what we can make together.</p>
    <a href="mailto:mac@macpeters.com" class="btn">Say Hello</a>
    <span class="contact-email">mac@macpeters.com</span>
  </section>

  <footer>
    <span>© 2026 Mac Peters</span>
    <span>Made with intention</span>
  </footer>

</body>
</html>
